{ "name": "Helena Richie", "short_name": "Helena Richie", "description": "I'm a Physics PhD candidate at the University of Pittsburgh working with Professor Evan Schneider on creating high resolution galaxy simulations. I'm interested in how dust affects galaxy evolution, specifically how it evolves and moves throughout galaxies.", "icons": [ { "src": "/assets/img/favicons/android-chrome-192x192.png", "sizes": "192x192", "type": "image/png" }, { "src": "/assets/img/favicons/android-chrome-512x512.png", "sizes": "512x512", "type": "image/png" }], "start_url": "/index.html", "theme_color": "#2a1e6b", "background_color": "#ffffff", "display": "fullscreen" }
